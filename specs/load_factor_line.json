{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Domestic passenger load factor over time — how full are Australian flights?",
  "width": "container",
  "height": 260,
  "data": { "url": "data/monthly_domestic.csv" },
  "transform": [
    { "filter": "datum.pax_lf != null && datum.pax_lf > 0 && datum.year >= 2005" },
    {
      "calculate": "{'Jan':1,'Feb':2,'Mar':3,'Apr':4,'May':5,'Jun':6,'Jul':7,'Aug':8,'Sep':9,'Oct':10,'Nov':11,'Dec':12}[datum.month]",
      "as": "month_num"
    },
    {
      "calculate": "datetime(datum.year, datum.month_num - 1, 1)",
      "as": "date"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#2a9d8f",
        "strokeDash": [4, 4],
        "opacity": 0.5,
        "strokeWidth": 1.5
      },
      "data": { "values": [{ "y": 80 }] },
      "encoding": {
        "y": { "field": "y", "type": "quantitative" }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#e9c46a",
        "strokeWidth": 1.5,
        "interpolate": "monotone",
        "opacity": 0.9
      },
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": null,
          "axis": {
            "labelColor": "#8aa4b8",
            "gridColor": "#1e3045",
            "domainColor": "#2d4a6a"
          }
        },
        "y": {
          "field": "pax_lf",
          "type": "quantitative",
          "title": "Load Factor (%)",
          "scale": { "domain": [20, 95] },
          "axis": {
            "labelColor": "#8aa4b8",
            "titleColor": "#8aa4b8",
            "gridColor": "#1e3045",
            "domainColor": "#2d4a6a"
          }
        },
        "tooltip": [
          { "field": "date", "type": "temporal", "title": "Month", "format": "%b %Y" },
          { "field": "pax_lf", "title": "Load Factor (%)", "format": ".1f" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 4,
        "fontSize": 10,
        "color": "#2a9d8f"
      },
      "data": { "values": [{ "date": "2026-01-01", "y": 80, "label": "80% benchmark" }] },
      "encoding": {
        "x": { "field": "date", "type": "temporal" },
        "y": { "field": "y", "type": "quantitative" },
        "text": { "field": "label" }
      }
    }
  ],
  "config": {
    "background": "#0d1b2a",
    "view": { "stroke": null }
  }
}