{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Top 20 busiest domestic routes in 2024 by passenger volume",
  "width": "container",
  "height": 420,
  "data": { "url": "data/route_annual.csv" },
  "transform": [
    { "filter": "datum.year == 2024" },
    { "filter": "datum.annual_pax != null && datum.annual_pax > 0" },
    {
      "window": [{ "op": "rank", "as": "rank" }],
      "sort": [{ "field": "annual_pax", "order": "descending" }]
    },
    { "filter": "datum.rank <= 20" },
    {
      "calculate": "datum.annual_pax / 1000000",
      "as": "pax_millions"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "pax_millions",
      "type": "quantitative",
      "title": "Annual Passengers (millions)",
      "axis": {
        "labelColor": "#8aa4b8",
        "titleColor": "#8aa4b8",
        "gridColor": "#1e3045",
        "domainColor": "#2d4a6a",
        "format": ".1f"
      }
    },
    "y": {
      "field": "route",
      "type": "nominal",
      "sort": { "field": "annual_pax", "order": "descending" },
      "title": null,
      "axis": {
        "labelColor": "#ccd6e0",
        "gridColor": "#1e3045",
        "domainColor": "#2d4a6a",
        "labelFontSize": 12
      }
    },
    "color": {
      "field": "avg_load_factor",
      "type": "quantitative",
      "title": "Load Factor (%)",
      "scale": {
        "domain": [50, 90],
        "range": ["#457b9d", "#f4a261"]
      },
      "legend": {
        "labelColor": "#ccd6e0",
        "titleColor": "#ccd6e0",
        "gradientLength": 120,
        "orient": "bottom-right"
      }
    },
    "tooltip": [
      { "field": "route", "title": "Route" },
      { "field": "pax_millions", "title": "Passengers (M)", "format": ".2f" },
      { "field": "avg_load_factor", "title": "Load Factor (%)", "format": ".1f" },
      { "field": "distance_km", "title": "Distance (km)", "format": "," }
    ]
  },
  "config": {
    "background": "#0d1b2a",
    "view": { "stroke": null }
  }
}